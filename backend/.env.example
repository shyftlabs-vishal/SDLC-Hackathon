# LLM provider: OPENAI or GEMINI
LLM_PROVIDER=GEMINI

# --- OpenAI (when LLM_PROVIDER=OPENAI) ---
#OPENAI_API_KEY=sk-your-key-here
# DEFAULT_LLM_MODEL=gpt-4o-mini
# LLM_FALLBACK_MODELS=gpt-4o

# --- Google Gemini (when LLM_PROVIDER=GEMINI) ---
 GEMINI_API_KEY=
# DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
# LLM_FALLBACK_MODELS=gemini/gemini-2.0-flash

# Optional — for private GitHub repos
# GITHUB_TOKEN=ghp_your-token-here

# Optional — JIRA Cloud integration (Tickets tab)
# JIRA_SITE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your-atlassian-api-token

# No Docker required for basic SDLC Conductor
MEMORY_ENABLED=false
SESSION_ENABLED=false
LANGFUSE_ENABLED=false

SDLC_CONDUCTOR_PORT=8096


SMART_GATEWAY_URL=
SMART_GATEWAY_API_KEY=
SMART_GATEWAY_DEFAULT_MODE=